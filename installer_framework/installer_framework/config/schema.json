{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tips.example/schema/installer-config.json",
  "title": "InstallerConfig",
  "type": "object",
  "required": ["branding", "install_scope", "steps", "actions"],
  "properties": {
    "product_id": {"type": "string"},
    "install_scope": {"type": "string", "enum": ["user", "system", "ask"]},
    "branding": {
      "type": "object",
      "required": ["productName", "publisher", "version"],
      "properties": {
        "productName": {"type": "string", "minLength": 1},
        "publisher": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "logoPath": {"type": "string"},
        "windowIconPath": {"type": "string"}
      },
      "additionalProperties": true
    },
    "theme": {
      "type": "object",
      "properties": {
        "style": {"type": "string", "enum": ["classic", "modern"]},
        "assets": {
          "type": "object",
          "properties": {
            "sidebar_image_path": {"type": "string"},
            "header_image_path": {"type": "string"}
          },
          "additionalProperties": true
        },
        "colors": {
          "type": "object",
          "properties": {
            "window_bg": {"type": "string"},
            "panel_bg": {"type": "string"},
            "text_primary": {"type": "string"},
            "border_light": {"type": "string"},
            "border_dark": {"type": "string"},
            "accent": {"type": "string"}
          },
          "additionalProperties": true
        },
        "metrics": {
          "type": "object",
          "properties": {
            "window_width": {"type": "integer", "minimum": 1},
            "window_height": {"type": "integer", "minimum": 1},
            "sidebar_width": {"type": "integer", "minimum": 1},
            "padding": {"type": "integer", "minimum": 1},
            "button_height": {"type": "integer", "minimum": 1}
          },
          "additionalProperties": true
        },
        "typography": {
          "type": "object",
          "properties": {
            "fonts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["font_family"],
                "properties": {
                  "font_family": {"type": "string", "minLength": 1},
                  "font_ttf_path": {"type": "string", "minLength": 1}
                },
                "additionalProperties": false
              }
            },
            "default_preset": {"type": "string", "minLength": 1},
            "presets": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "object",
                "required": ["title", "text"],
                "properties": {
                  "title": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["font_family", "font_size"],
                      "properties": {
                        "font_family": {"type": "string", "minLength": 1},
                        "font_size": {"type": "integer", "minimum": 1}
                      },
                      "additionalProperties": false
                    }
                  },
                  "text": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["font_family", "font_size"],
                      "properties": {
                        "font_family": {"type": "string", "minLength": 1},
                        "font_size": {"type": "integer", "minimum": 1}
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "required": ["fonts", "presets"],
          "not": {
            "anyOf": [
              {"required": ["font_name"]},
              {"required": ["base_size"]},
              {"required": ["title_size"]}
            ]
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "type": {"type": "string", "minLength": 1},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "header_description": {"type": "string"},
          "body_description": {"type": "string"},
          "typography_preset": {"type": "string", "minLength": 1},
          "show_if": {"type": "string"},
          "license_path": {"type": "string"},
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "label"],
              "properties": {
                "id": {"type": "string"},
                "type": {
                  "type": "string",
                  "enum": [
                    "text",
                    "password",
                    "checkbox",
                    "select",
                    "multiselect",
                    "directory"
                  ]
                },
                "label": {"type": "string"},
                "default": {},
                "placeholder": {"type": "string"},
                "required": {"type": "boolean"},
                "regex": {"type": "string"},
                "min_length": {"type": "integer", "minimum": 0},
                "max_length": {"type": "integer", "minimum": 0},
                "choices": {"type": "array", "items": {"type": "string"}},
                "validators": {"type": "array", "items": {"type": "string"}},
                "show_if": {"type": "string"},
                "complexity": {"type": "boolean"}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "description": {"type": "string"},
          "default": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"type": "string", "minLength": 1},
          "rollback": {"type": "string", "enum": ["auto", "delete_only", "none"]},
          "manifest_file": {"type": "string", "minLength": 1},
          "target_path": {"type": "string", "minLength": 1},
          "append": {"type": "boolean"},
          "content": {},
          "undo_path": {"type": "string"},
          "uninstall_path": {"type": "string"}
        },
        "allOf": [
          {
            "if": {
              "properties": {"type": {"const": "copy_files"}},
              "required": ["type"]
            },
            "then": {
              "required": ["manifest_file"],
              "not": {
                "anyOf": [
                  {"required": ["items"]},
                  {"required": ["overwrite"]}
                ]
              }
            }
          },
          {
            "if": {
              "properties": {"type": {"const": "write_dotfile"}},
              "required": ["type"]
            },
            "then": {
              "required": ["target_path"],
              "not": {
                "anyOf": [
                  {"required": ["scope"]},
                  {"required": ["user_base"]},
                  {"required": ["system_base"]},
                  {"required": ["file_name"]}
                ]
              }
            }
          },
          {
            "if": {
              "properties": {"type": {"const": "run_script"}},
              "required": ["type"]
            },
            "then": {
              "anyOf": [
                {
                  "properties": {"rollback": {"const": "none"}},
                  "required": ["rollback"]
                },
                {"required": ["undo_path"]}
              ]
            }
          }
        ],
        "additionalProperties": true
      }
    },
    "windows": {
      "type": "object",
      "properties": {
        "allow_uac_elevation": {"type": "boolean"},
        "prefer_program_files_x86": {"type": "boolean"},
        "installer_icon_ico": {"type": "string"}
      },
      "additionalProperties": true
    },
    "macos": {
      "type": "object",
      "properties": {
        "installer_icon_icns": {"type": "string"}
      },
      "additionalProperties": true
    },
    "unix": {
      "type": "object",
      "properties": {
        "allow_sudo_relaunch": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "shortcut": {"type": "object", "additionalProperties": true},
    "upgrade": {"type": "object", "additionalProperties": true},
    "uninstall": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "modified_file_policy": {"type": "string", "enum": ["prompt", "skip", "delete"]},
        "unix": {
          "type": "object",
          "properties": {
            "create_symlink": {"type": "boolean"},
            "user_link_path": {"type": "string"},
            "system_link_path": {"type": "string"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "hooks": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": true
}
